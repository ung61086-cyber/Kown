-- [[ 2. HỆ THỐNG VẼ ESP & VÒNG TRÒN FOV ]] --
local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 1.5; FOVCircle.Color = Global_Green; FOVCircle.Filled = false

local function CreateESP(plr)
    local Line = Drawing.new("Line"); local Box = Drawing.new("Square"); local Health = Drawing.new("Text")
    RunService.RenderStepped:Connect(function()
        if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr ~= LocalPlayer then
            local HRP = plr.Character.HumanoidRootPart
            local Pos, OnScreen = Camera:WorldToViewportPoint(HRP.Position)
            if OnScreen then
                Line.Visible = _G.Config.ESP_Line; Line.From = Vector2.new(Camera.ViewportSize.X / 2, 0); Line.To = Vector2.new(Pos.X, Pos.Y); Line.Color = Global_Green; Line.Thickness = 1.5
                if _G.Config.ESP_Box then
                    local SizeX, SizeY = 2500 / Pos.Z, 3500 / Pos.Z
                    Box.Visible = true; Box.Size = Vector2.new(SizeX, SizeY); Box.Position = Vector2.new(Pos.X - SizeX / 2, Pos.Y - SizeY / 2); Box.Color = Global_Green
                else Box.Visible = false end
                Health.Visible = _G.Config.ESP_HP; local hum = plr.Character:FindFirstChild("Humanoid")
                Health.Text = hum and math.floor(hum.Health) .. " HP" or "0 HP"; Health.Position = Vector2.new(Pos.X, Pos.Y + 10); Health.Color = Global_Green; Health.Center = true
            else Line.Visible = false; Box.Visible = false; Health.Visible = false end
        else Line.Visible = false; Box.Visible = false; Health.Visible = false end
    end)
end

-- [[ 3. LOGIC KILL ALL & AUTO HEAL ]] --
task.spawn(function()
    while task.wait() do
        if _G.Config.KillAll then
            pcall(function()
                for _, v in pairs(Players:GetPlayers()) do
                    if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                        local hum = v.Character:FindFirstChild("Humanoid")
                        if hum and hum.Health > 0 then
                            local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool") or LocalPlayer.Backpack:FindFirstChildOfClass("Tool")
                            if tool then
                                if tool.Parent == LocalPlayer.Backpack then LocalPlayer.Character.Humanoid:EquipTool(tool) end
                                -- Dịch chuyển và khóa vị trí cực nhanh
                                while _G.Config.KillAll and hum.Health > 0 do
                                    LocalPlayer.Character.HumanoidRootPart.CFrame = v.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
                                    LocalPlayer.Character.HumanoidRootPart.Velocity = Vector3.new(0,0,0)
                                    tool:Activate()
                                    task.wait() -- Chém nhanh theo tốc độ server
                                end
                            end
                        end
                    end
                end
            end)
        end
        if _G.Config.AutoHeal and LocalPlayer.Character:FindFirstChild("Humanoid") then
            if LocalPlayer.Character.Humanoid.Health < 50 then
                LocalPlayer.Character.HumanoidRootPart.Velocity = Vector3.new(0,0,0)
            end
        end
    end
end)

