    local Box = Instance.new("TextBox", Frame); Box.Size = UDim2.new(0, 240, 0, 40); Box.Position = UDim2.new(0.5, -120, 0.3, 0); Box.PlaceholderText = "Key: tudeptrai2013"; Box.BackgroundColor3 = Color3.fromRGB(40,40,40); Box.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", Box)
    local B = Instance.new("TextButton", Frame); B.Size = UDim2.new(0, 100, 0, 35); B.Position = UDim2.new(0.5, -50, 0.7, 0); B.Text = "LOGIN"; B.BackgroundColor3 = Global_Red; B.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", B)
    
