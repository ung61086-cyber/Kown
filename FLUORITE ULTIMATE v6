-- [[ 1. KHỞI TẠO HỆ THỐNG & CẤU HÌNH ]] --
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local Global_Red = Color3.fromRGB(255, 0, 0)
local Global_Green = Color3.fromRGB(0, 255, 127)

local KeyDatabase = {
    ["tudeptrai2013"] = 863913600, -- VIP ADMIN
    ["tuDepTrai"] = 86400
}

_G.Config = {
    Aimbot = false, ShowFOV = false, FOVSize = 120,
    Smoothness = 0.1, AimPart = "Head",
    ESP_Box = false, ESP_HP = false, ESP_Line = false,
    HitboxHead = false,
    HitboxBody = false,
    HitboxSize = 20
}

-- [[ 2. HỆ THỐNG VẼ VÀ AIMBOT ]] --
local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 1.5; FOVCircle.Color = Global_Red; FOVCircle.Filled = false

local function GetClosestPlayer()
    local target = nil
    local shortestDistance = _G.Config.FOVSize
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild(_G.Config.AimPart) then
            local Hum = v.Character:FindFirstChild("Humanoid")
            if Hum and Hum.Health > 0 then
                local pos, onScreen = Camera:WorldToViewportPoint(v.Character[_G.Config.AimPart].Position)
                if onScreen then
                    local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                    if dist < shortestDistance then
                        target = v; shortestDistance = dist
                    end
                end
            end
        end
    end
    return target
end

-- [[ 3. HỆ THỐNG ESP & LOGIC HITBOX (CHỐNG KẸT) ]] --
local function CreateESP(plr)
    local Lines = {
        TL1 = Drawing.new("Line"), TL2 = Drawing.new("Line"),
        TR1 = Drawing.new("Line"), TR2 = Drawing.new("Line"),
        BL1 = Drawing.new("Line"), BL2 = Drawing.new("Line"),
        BR1 = Drawing.new("Line"), BR2 = Drawing.new("Line")
    }
    local MainLine = Drawing.new("Line")
    local HealthBarBack = Drawing.new("Line")
    local HealthBar = Drawing.new("Line")
    local HealthText = Drawing.new("Text")

    RunService.RenderStepped:Connect(function()
        -- Cập nhật FOV Circle
        FOVCircle.Visible = _G.Config.ShowFOV
        FOVCircle.Radius = _G.Config.FOVSize
        FOVCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)

        -- Logic Aimbot
        if _G.Config.Aimbot then
            local t = GetClosestPlayer()
            if t then
                Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, t.Character[_G.Config.AimPart].Position), _G.Config.Smoothness)
            end
        end

        -- Logic Hitbox & ESP
        if plr.Character and plr ~= LocalPlayer then
            local Root = plr.Character:FindFirstChild("HumanoidRootPart")
            local Head = plr.Character:FindFirstChild("Head")
            local Hum = plr.Character:FindFirstChild("Humanoid")

            if Root and Head and Hum and Hum.Health > 0 then
                -- XỬ LÝ HITBOX VÀ CHỐNG KẸT
                if _G.Config.HitboxHead then
                    Head.Size = Vector3.new(_G.Config.HitboxSize, _G.Config.HitboxSize, _G.Config.HitboxSize)
                    Head.Transparency = 0.7; Head.CanCollide = false
                else
                    Head.Size = Vector3.new(1.2, 1.2, 1.2); Head.Transparency = 0
                end

                if _G.Config.HitboxBody then
                    Root.Size = Vector3.new(_G.Config.HitboxSize, _G.Config.HitboxSize, _G.Config.HitboxSize)
                    Root.Transparency = 0.8; Root.CanCollide = false
                else
                    Root.Size = Vector3.new(2, 2, 1); Root.Transparency = 1
                end

                -- Ép buộc đi xuyên qua đối thủ nếu đang bật Hitbox
                if _G.Config.HitboxHead or _G.Config.HitboxBody then
                    for _, part in pairs(plr.Character:GetChildren()) do
                        if part:IsA("BasePart") then part.CanCollide = false end
                    end
                end

                -- VẼ ESP
                local Pos, OnScreen = Camera:WorldToViewportPoint(Root.Position)
                if OnScreen then
                    local SizeX, SizeY = 2200 / Pos.Z, 3200 / Pos.Z
                    local X, Y = Pos.X, Pos.Y
                    local Factor = SizeX * 0.25

                    -- Vẽ Box 4 góc
                    for _, l in pairs(Lines) do l.Visible = _G.Config.ESP_Box; l.Color = Global_Red; l.Thickness = 1.5 end
                    if _G.Config.ESP_Box then
                        Lines.TL1.From = Vector2.new(X - SizeX/2, Y - SizeY/2); Lines.TL1.To = Vector2.new(X - SizeX/2 + Factor, Y - SizeY/2)
                        Lines.TL2.From = Vector2.new(X - SizeX/2, Y - SizeY/2); Lines.TL2.To = Vector2.new(X - SizeX/2, Y - SizeY/2 + Factor)
                        Lines.TR1.From = Vector2.new(X + SizeX/2, Y - SizeY/2); Lines.TR1.To = Vector2.new(X + SizeX/2 - Factor, Y - SizeY/2)
                        Lines.TR2.From = Vector2.new(X + SizeX/2, Y - SizeY/2); Lines.TR2.To = Vector2.new(X + SizeX/2, Y - SizeY/2 + Factor)
                        Lines.BL1.From = Vector2.new(X - SizeX/2, Y + SizeY/2); Lines.BL1.To = Vector2.new(X - SizeX/2 + Factor, Y + SizeY/2)
                        Lines.BL2.From = Vector2.new(X - SizeX/2, Y + SizeY/2); Lines.BL2.To = Vector2.new(X - SizeX/2, Y + SizeY/2 - Factor)
                        Lines.BR1.From = Vector2.new(X + SizeX/2, Y + SizeY/2); Lines.BR1.To = Vector2.new(X + SizeX/2 - Factor, Y + SizeY/2)
                        Lines.BR2.From = Vector2.new(X + SizeX/2, Y + SizeY/2); Lines.BR2.To = Vector2.new(X + SizeX/2, Y + SizeY/2 - Factor)
                    end

                    -- Vẽ Máu trái
                    if _G.Config.ESP_HP then
                        local BarX = X - SizeX/2 - 6
                        HealthBarBack.Visible = true; HealthBarBack.From = Vector2.new(BarX, Y + SizeY/2); HealthBarBack.To = Vector2.new(BarX, Y - SizeY/2); HealthBarBack.Color = Color3.new(0,0,0); HealthBarBack.Thickness = 4
                        local HealthH = (Hum.Health / Hum.MaxHealth) * SizeY
                        HealthBar.Visible = true; HealthBar.From = Vector2.new(BarX, Y + SizeY/2); HealthBar.To = Vector2.new(BarX, (Y + SizeY/2) - HealthH); HealthBar.Color = Global_Green:Lerp(Global_Red, 1-(Hum.Health/Hum.MaxHealth)); HealthBar.Thickness = 2
                        HealthText.Visible = true; HealthText.Text = math.floor(Hum.Health); HealthText.Position = Vector2.new(BarX - 15, (Y + SizeY/2) - HealthH - 7); HealthText.Color = Color3.new(1,1,1); HealthText.Outline = true; HealthText.Size = 12
                    else HealthBarBack.Visible = false; HealthBar.Visible = false; HealthText.Visible = false end

                    MainLine.Visible = _G.Config.ESP_Line; MainLine.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y); MainLine.To = Vector2.new(X, Y + SizeY/2); MainLine.Color = Global_Red
                else
                    for _, l in pairs(Lines) do l.Visible = false end
                    MainLine.Visible = false; HealthBarBack.Visible = false; HealthBar.Visible = false; HealthText.Visible = false
                end
            else
                for _, l in pairs(Lines) do l.Visible = false end
                MainLine.Visible = false; HealthBarBack.Visible = false; HealthBar.Visible = false; HealthText.Visible = false
            end
        end
    end)
end

