    local Screen = Instance.new("ScreenGui", LocalPlayer.PlayerGui); Screen.ResetOnSpawn = false
    local Main = Instance.new("Frame", Screen); Main.Size = UDim2.new(0, 260, 0, 450); Main.Position = UDim2.new(0.5, -130, 0.5, -225); Main.BackgroundColor3 = Color3.fromRGB(15, 15, 15); Main.Draggable = true; Main.Active = true; Instance.new("UICorner", Main)
    
    local Head = Instance.new("Frame", Main); Head.Size = UDim2.new(1, 0, 0, 40); Head.BackgroundColor3 = Global_Red; Instance.new("UICorner", Head)
    local T = Instance.new("TextLabel", Head); T.Size = UDim2.new(1,0,1,0); T.Text = "FLUORITE MENU VIP"; T.TextColor3 = Color3.new(1,1,1); T.Font = "GothamBold"; T.TextSize = 14; T.BackgroundTransparency = 1

    local M = Instance.new("TextButton", Screen); M.Size = UDim2.new(0, 40, 0, 40); M.Position = UDim2.new(0, 10, 0.5, -20); M.Text = "F"; M.BackgroundColor3 = Global_Red; M.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", M).CornerRadius = UDim.new(1,0)
    M.MouseButton1Click:Connect(function() Main.Visible = not Main.Visible end)

    local function CreateBtn(name, configKey, y)
        local b = Instance.new("TextButton", Main); b.Size = UDim2.new(0, 220, 0, 35); b.Position = UDim2.new(0.5, -110, 0, y); b.Text = name; b.BackgroundColor3 = Color3.fromRGB(30, 30, 30); b.TextColor3 = Color3.new(1,1,1); b.Font = "GothamBold"; b.TextSize = 10; Instance.new("UICorner", b)
        b.MouseButton1Click:Connect(function()
            _G.Config[configKey] = not _G.Config[configKey]
            b.TextColor3 = _G.Config[configKey] and Global_Green or Color3.new(1,1,1)
        end)
    end

    CreateBtn("ANTENNA (VẠCH KẺ)", "ESP_Line", 60)
    CreateBtn("KHUNG NHÌN 4 GÓC", "ESP_Box", 105)
    CreateBtn("MÁU BÊN TRÁI", "ESP_HP", 150)
    CreateBtn("AUTO AIMBOT", "Aimbot", 195)
    CreateBtn("HITBOX KHỔNG LỒ", "Hitbox", 240)
    CreateBtn("QUÉT MAP (KILL ALL)", "KillAll", 320)
end

-- [[ 5. HỆ THỐNG KEY ]] --
local function CreateKeySystem()
    local KeyGui = Instance.new("ScreenGui", LocalPlayer.PlayerGui)
    local Frame = Instance.new("Frame", KeyGui); Frame.Size = UDim2.new(0, 300, 0, 180); Frame.Position = UDim2.new(0.5, -150, 0.5, -90); Frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20); Instance.new("UICorner", Frame)
    local Box = Instance.new("TextBox", Frame); Box.Size = UDim2.new(0, 240, 0, 40); Box.Position = UDim2.new(0.5, -120, 0.4, 0); Box.PlaceholderText = "Key: tudeptrai2013"; Box.BackgroundColor3 = Color3.fromRGB(35, 35, 35); Box.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", Box)
    local B = Instance.new("TextButton", Frame); B.Size = UDim2.new(0, 100, 0, 35); B.Position = UDim2.new(0.5, -50, 0.75, 0); B.Text = "LOGIN"; B.BackgroundColor3 = Global_Red; B.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", B)
    B.MouseButton1Click:Connect(function() if Box.Text == "tudeptrai2013" then KeyGui:Destroy(); LaunchMenu() end end)
end

for _, v in pairs(Players:GetPlayers()) do CreateESP(v) end
Players.PlayerAdded:Connect(CreateESP)
CreateKeySystem()
